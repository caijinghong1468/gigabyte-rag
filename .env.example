# Copy to .env and edit as needed. All values have defaults in src/rag/config.py.
# docker-compose reads HF_TOKEN and MODEL from this file.

# --- Hugging Face token (for gated repos) ---
# Leave blank for the default public GGUFs. Paste a token here ONLY if you point
# MODEL_REPO at a gated repo (e.g. an official meta-llama repo). Format:
HF_TOKEN=

# --- Which model stack to run: qwen | llama ---
# Selects a preset (repo + GGUF file + prompt format) from src/rag/config.py.
#   qwen  -> MaziyarPanahi/Qwen3-1.7B-GGUF            (ChatML, thinking toggle)
#   llama -> bartowski/Llama-3.2-3B-Instruct-GGUF     (Llama-3 header template)
# Used by the default `rag` service. The pinned rag-qwen / rag-llama services
# ignore this and force their own model.
MODEL=qwen

# --- LLM overrides (optional; normally driven by MODEL above) ---
# MODEL_REPO=bartowski/Llama-3.2-3B-Instruct-GGUF
# MODEL_FILE=Llama-3.2-3B-Instruct-Q4_K_M.gguf
# PROMPT_FORMAT=llama3        # qwen | llama3
# MODEL_PATH=/app/models/llama/Llama-3.2-3B-Instruct-Q4_K_M.gguf  # absolute path wins
N_CTX=4096
N_GPU_LAYERS=-1              # -1 = all layers on GPU
MAIN_GPU=0
CUDA_VISIBLE_DEVICES=0
FLASH_ATTN=true
ENABLE_THINKING=false        # keep Qwen3 thinking OFF for fast, clean answers
MAX_TOKENS=512
TEMPERATURE=0.2

# --- Embedding (shared by every model; GGUF via llama.cpp, on CPU) ---
EMBED_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
EMBED_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf
EMBED_N_GPU_LAYERS=0         # 0 = CPU (keep VRAM for the LLM)

# --- Retrieval ---
TOP_K=7
DENSE_TOP_K=10
LEXICAL_TOP_K=10
USE_HYBRID=true
RRF_K=60

# --- Server ---
HOST=0.0.0.0
PORT=8000
